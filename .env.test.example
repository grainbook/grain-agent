# Copy to `.env.test` and fill in your real provider keys.
# `.env.test` is gitignored — never leaves your machine.
#
# These keys are picked up by the live integration tests in
# `grain-ai-agent-headless/tests/live.rs` and
# `grain-llm-genai/tests/live.rs`. Both are `#[ignore]`-gated, so they
# only run when you opt in:
#
#   cargo test -p grain-ai-agent-headless --test live -- --ignored
#   cargo test -p grain-llm-genai      --test live -- --ignored
#
# DeepSeek is the default for the headless suite — cheap, fast, and the
# `deepseek-chat` model is a solid coding agent.
DEEPSEEK_API_KEY=

# Optional: keys for other live suites. Tests that need them are
# individually `#[ignore]`-gated, so a missing key just means that one
# test is skipped.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# MOONSHOT_API_KEY=
# SILICONFLOW_API_KEY=

# Optional model override. Defaults to "deepseek/deepseek-chat" for the
# headless live suite when not set.
# GRAIN_LIVE_TEST_MODEL=deepseek/deepseek-chat

# Optional workspace override. Defaults to the cargo manifest dir
# (i.e. the agent reads its own source code). Point this at a small
# scratch directory if you want a cleaner test setup.
# GRAIN_LIVE_TEST_WORKSPACE=/tmp/grain-live-scratch

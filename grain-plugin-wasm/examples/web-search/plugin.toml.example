# Example manifest for the web-search WASM plugin.
# Copy this to `<workspace>/.grain/plugins/web-search/plugin.toml`
# next to the compiled `plugin.wasm`.

name = "web-search"
version = "0.1.0"
description = "Exa search + URL fetch (WASM, sandboxed)"
author = "grain"

[wasm]
# `http` — host_http_get / host_http_post  (REQUIRED: Exa API + fetch)
# `env`  — host_env_get                    (REQUIRED: read EXA_API_KEY)
# `log`  — host_log                        (recommended: see plugin logs)
capabilities = ["http", "env", "log"]
